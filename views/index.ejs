<%- include('partials/header') %>

<section class="hero">
  <img src="/images/logo.svg" alt="Milanorte" class="hero-logo">
  <p class="slogan">Desde nuestra cocina hasta tu mesa 🍽️</p>
  <p class="tagline">La milanesa no es solo comida, es el clásico que une a la familia.</p>
</section>

<div class="container">

  <!-- Intro Section -->
  <section class="intro-section">
    <p class="intro-highlight">
      "¿Otra vez milanesas?"
    </p>
    <p>
      Porque no hay nadie que diga que no a una buena milanesa,
      porque es la respuesta correcta cuando no sabés qué cocinar,
      porque es el plato que siempre pide repetición,
      porque sí.
    </p>
    <p>
      Crujiente por fuera, tierna por dentro… y lista en minutos.
    </p>
    <p class="intro-cta">
      👉 Hacé tu pedido hoy y olvidate de cocinar.
    </p>
    <p class="intro-footer">
      "Si hay milanesas, está todo bien."
    </p>
  </section>

  <!-- Ingredients Section -->
  <section class="features-section">
    <div class="feature">
      <div class="feature-icon">&#9733;</div>
      <h3>Los mejores ingredientes</h3>
      <p>Carne seleccionada de primera calidad. Rebozado casero con pan rallado premium. Sin conservantes.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">&#10052;</div>
      <h3>Congeladas al instante</h3>
      <p>Congelado rápido para mantener toda la frescura y el sabor. De nuestras manos a tu freezer, listas para disfrutar.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">&#9201;</div>
      <h3>Listas en minutos</h3>
      <p>Ideales para freír o llevar al horno. Perfectas para reuniones, cumples, o simplemente porque hoy toca milanesa.</p>
    </div>
  </section>

  <!-- Products -->
  <h2 class="section-title">Nuestras milanesas</h2>
  <p class="section-subtitle">Pedido mínimo: 2 kg por variedad</p>

  <form id="order-form" action="/order" method="POST" data-free-shipping-threshold="<%= freeShippingThreshold %>" data-phone-verification="<%= phoneVerificationEnabled ? '1' : '0' %>">
    <div class="products">
      <% products.forEach((p, i) => { %>
        <div class="product-card" data-price-per-kg="<%= p.pricePerKg %>" data-min-kg="<%= p.minKg %>">
          <img src="<%= p.image %>" alt="<%= p.title %>">
          <div class="product-info">
            <h3><%= p.title %></h3>
            <p class="weight">Precio por kilo &middot; Mínimo <%= p.minKg %>kg</p>
            <p class="price"><%= formatPrice(p.pricePerKg) %> <span>/ kg</span></p>
            <div class="qty-selector">
              <button type="button" class="qty-btn" data-action="minus">&#8722;</button>
              <span class="qty-value">0</span>
              <span class="qty-unit">kg</span>
              <button type="button" class="qty-btn" data-action="plus">+</button>
              <input type="hidden" class="qty-input" name="qty_<%= i === 0 ? 'nalga' : 'bife' %>" value="0">
            </div>
            <p class="product-subtotal"></p>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="order-section">
      <h2>Día de entrega</h2>
      <p style="color: var(--gray); margin-bottom: 1rem; font-size: 0.9rem;">Hacemos envíos los miércoles y sábados</p>
      <div class="delivery-options">
        <div class="delivery-option">
          <input type="radio" id="del-mier" name="delivery_day" value="miercoles">
          <label for="del-mier">Miércoles</label>
        </div>
        <div class="delivery-option">
          <input type="radio" id="del-sab" name="delivery_day" value="sabado">
          <label for="del-sab">Sábado</label>
        </div>
      </div>

      <div class="time-slots" id="time-slots" style="display: none;">
        <p style="font-weight: 600; margin-bottom: 0.75rem;">Horario de entrega</p>
        <div class="delivery-options">
          <div class="delivery-option">
            <input type="radio" id="slot-manana" name="delivery_slot" value="manana">
            <label for="slot-manana">Mañana<span class="slot-time">10 a 13hs</span></label>
          </div>
          <div class="delivery-option">
            <input type="radio" id="slot-tarde" name="delivery_slot" value="tarde">
            <label for="slot-tarde">Tarde<span class="slot-time">13 a 18hs</span></label>
          </div>
          <div class="delivery-option">
            <input type="radio" id="slot-noche" name="delivery_slot" value="noche">
            <label for="slot-noche">Noche<span class="slot-time">18 a 20hs</span></label>
          </div>
        </div>
      </div>
    </div>

    <div class="order-section">
      <h2>Tus datos</h2>
      <div class="form-group">
        <label for="name">Nombre completo *</label>
        <input type="text" id="name" name="customer_name" required>
      </div>
      <div class="form-group">
        <label for="phone">Teléfono / WhatsApp *</label>
        <input type="tel" id="phone" name="customer_phone" required placeholder="Ej: 1155667788 (10 dígitos, sin 0 ni 15)" maxlength="15">
        <small id="phone-error" style="color: #c62828; display: none;"></small>
        <div id="phone-verify-section" style="display: none; margin-top: 0.5rem;">
          <small id="phone-verify-msg" style="color: #c62828; font-weight: 600;">Verificá tu teléfono por WhatsApp para continuar</small>
          <div id="phone-verify-actions" style="margin-top: 0.5rem;">
            <button type="button" id="btn-send-code" class="btn btn-secondary btn-small" style="display: none;">Verificar teléfono</button>
            <span id="phone-sending" style="display: none; color: var(--gray);">Enviando código...</span>
          </div>
          <div id="phone-code-section" style="display: none; margin-top: 0.5rem;">
            <small>Ingresá el código de 6 dígitos que te enviamos por WhatsApp:</small>
            <div style="display: flex; gap: 0.5rem; margin-top: 0.25rem;">
              <input type="text" id="phone-code" maxlength="6" placeholder="000000" style="width: 120px; text-align: center; font-size: 1.2rem; letter-spacing: 0.3rem;">
              <button type="button" id="btn-verify-code" class="btn btn-secondary btn-small">Confirmar</button>
            </div>
            <small id="phone-code-error" style="color: #c62828; display: none;"></small>
            <button type="button" id="btn-resend-code" class="btn btn-small" style="display: none; margin-top: 0.25rem; font-size: 0.8rem; background: none; color: var(--gold-dark); text-decoration: underline; padding: 0;">Reenviar código</button>
          </div>
          <div id="phone-verified" style="display: none; color: #2e7d32; font-weight: 600;">
            Teléfono verificado ✓
          </div>
        </div>
      </div>
      <div class="form-group">
        <label for="email">Email (opcional)</label>
        <input type="email" id="email" name="customer_email">
      </div>
      <div class="form-group">
        <label for="address">Dirección de entrega *</label>
        <input type="text" id="address" name="customer_address" required placeholder="Calle, número, piso, localidad" autocomplete="off">
        <input type="hidden" id="customer_lat" name="customer_lat" value="">
        <input type="hidden" id="customer_lng" name="customer_lng" value="">
        <div id="address-map" style="display: none; height: 200px; border-radius: 6px; margin-top: 0.5rem;"></div>
        <div id="shipping-info" style="display: none; margin-top: 0.5rem;"></div>
      </div>

      <p style="text-align: right; font-size: 1.4rem; font-weight: 600; margin-top: 1.5rem;">
        Total: <span id="order-total">$0</span>
      </p>

      <button type="submit" id="submit-order" class="btn btn-primary" disabled>Hacer pedido</button>
      <small id="submit-hint" style="display: block; text-align: center; color: #c62828; margin-top: 0.5rem;"></small>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
