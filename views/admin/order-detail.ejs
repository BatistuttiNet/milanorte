<%- include('../partials/header') %>

<div class="container">
  <a href="/admin" style="color: var(--gold-dark); text-decoration: none; font-weight: 500;">&#8592; Volver a pedidos</a>

  <div class="order-detail" style="margin-top: 1rem;">
    <h2>Pedido #<%= order.id %> <span class="status-badge status-<%= order.status %>"><%= order.status %></span></h2>

    <div class="detail-grid">
      <div class="detail-item">
        <label>Cliente</label>
        <span><%= order.customer_name %></span>
      </div>
      <div class="detail-item">
        <label>Teléfono</label>
        <span><%= order.customer_phone %></span>
      </div>
      <div class="detail-item">
        <label>Email</label>
        <span><%= order.customer_email || '-' %></span>
      </div>
      <div class="detail-item" style="grid-column: 1 / -1;">
        <label>Dirección</label>
        <span><%= order.customer_address %><% if (order.address_extra) { %> (<%= order.address_extra %>)<% } %></span>
        <div style="margin-top: 0.5rem;">
          <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(order.customer_address) %>" target="_blank" rel="noopener" style="color: var(--gold-dark); font-size: 0.9rem;">Ver en Google Maps &#8599;</a>
        </div>
      </div>
      <div class="detail-item">
        <label>Día de entrega</label>
        <span><% if (order.delivery_slot) { %><%= order.delivery_day === 'miercoles' ? 'Miércoles' : 'Sábado' %> — <%= order.delivery_slot === 'manana' ? 'Mañana (9-12)' : order.delivery_slot === 'tarde' ? 'Tarde (13-17)' : 'Noche (18-20)' %><% } else { %>A convenir<% } %></span>
      </div>
      <div class="detail-item">
        <label>Zona</label>
        <span>Zona Norte</span>
      </div>
      <% if (order.discount_amount > 0) { %>
        <div class="detail-item">
          <label>Descuento</label>
          <span><%= order.discount_code %> (-<%= order.discount_percent %>%) — <%= formatPrice(order.discount_amount) %></span>
        </div>
      <% } %>
      <div class="detail-item">
        <label>Fecha pedido</label>
        <span><%= order.created_at %></span>
      </div>
    </div>

    <table class="checkout-table">
      <thead>
        <tr>
          <th>Producto</th>
          <th>Cantidad</th>
          <th>Precio unit.</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(item => { %>
          <tr>
            <td><%= item.product %></td>
            <td><%= item.quantity %></td>
            <td>$<%= item.unit_price %></td>
            <td>$<%= item.quantity * item.unit_price %></td>
          </tr>
        <% }) %>
        <% if (order.discount_amount > 0) { %>
          <tr>
            <td colspan="3" style="text-align: right;">Subtotal</td>
            <td>$<%= order.subtotal_amount %></td>
          </tr>
          <tr style="color: var(--green);">
            <td colspan="3" style="text-align: right;">Descuento (<%= order.discount_code %> -<%= order.discount_percent %>%)</td>
            <td>-$<%= order.discount_amount %></td>
          </tr>
        <% } %>
        <tr class="total-row">
          <td colspan="3">Total</td>
          <td>$<%= order.total_amount %></td>
        </tr>
      </tbody>
    </table>

    <div style="background: var(--cream); padding: 1rem; border-radius: 8px; margin-top: 1rem;">
      <label style="font-size: 0.8rem; text-transform: uppercase; color: var(--gray);">MercadoPago — Conciliación</label>
      <% if (order.mp_payment_id) { %>
        <p><strong>N° Pago:</strong> <%= order.mp_payment_id %></p>
        <% if (order.mp_status) { %><p><strong>Estado MP:</strong> <%= order.mp_status %></p><% } %>
      <% } else { %>
        <p style="color: #c62828;">Sin pago registrado</p>
      <% } %>
      <% if (order.mp_preference_id) { %><p style="font-size: 0.85rem; color: var(--gray);">Preference: <%= order.mp_preference_id %></p><% } %>
    </div>

    <form action="/admin/orders/<%= order.id %>/status" method="POST" class="status-form">
      <label style="font-weight: 600;">Cambiar estado:</label>
      <select name="status">
        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pendiente</option>
        <option value="paid" <%= order.status === 'paid' ? 'selected' : '' %>>Pagado</option>
        <option value="preparing" <%= order.status === 'preparing' ? 'selected' : '' %>>Preparando</option>
        <option value="ready" <%= order.status === 'ready' ? 'selected' : '' %>>Listo</option>
        <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Entregado</option>
        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelado</option>
      </select>
      <button type="submit" class="btn btn-secondary btn-small">Guardar</button>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
