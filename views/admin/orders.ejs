<%- include('../partials/header') %>

<div class="container">
  <div class="admin-header">
    <h2>Pedidos</h2>
    <div class="admin-filters">
      <a href="/admin" class="<%= currentFilter === 'all' ? 'active' : '' %>">Todos</a>
      <a href="/admin?status=pending" class="<%= currentFilter === 'pending' ? 'active' : '' %>">Pendientes</a>
      <a href="/admin?status=paid" class="<%= currentFilter === 'paid' ? 'active' : '' %>">Pagados</a>
      <a href="/admin?status=preparing" class="<%= currentFilter === 'preparing' ? 'active' : '' %>">Preparando</a>
      <a href="/admin?status=ready" class="<%= currentFilter === 'ready' ? 'active' : '' %>">Listos</a>
      <a href="/admin?status=delivered" class="<%= currentFilter === 'delivered' ? 'active' : '' %>">Entregados</a>
      <a href="/admin?delivery=miercoles" class="<%= currentFilter === 'miercoles' ? 'active' : '' %>">Mie</a>
      <a href="/admin?delivery=sabado" class="<%= currentFilter === 'sabado' ? 'active' : '' %>">Sab</a>
      <a href="/admin/settings" style="margin-left: 1rem; font-weight: 600;">⚙ Config</a>
    </div>
    <a href="/admin/logout" class="btn btn-small btn-secondary">Salir</a>
  </div>

  <% if (orders.length === 0) { %>
    <p style="text-align:center; color: var(--gray); padding: 3rem;">No hay pedidos</p>
  <% } else { %>
    <table class="orders-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Cliente</th>
          <th>Tel</th>
          <th>Productos</th>
          <th>Total</th>
          <th>Entrega</th>
          <th>Estado</th>
          <th>Fecha</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(o => {
          const items = JSON.parse(o.items_json);
          const summary = items.map(i => i.quantity + 'x ' + i.product.replace('Milanesas de ','')).join(', ');
        %>
          <tr onclick="location.href='/admin/orders/<%= o.id %>'" style="cursor:pointer">
            <td><strong><%= o.id %></strong></td>
            <td><%= o.customer_name %></td>
            <td><%= o.customer_phone %></td>
            <td><%= summary %></td>
            <td>$<%= o.total_amount %></td>
            <td><%= o.delivery_day === 'miercoles' ? 'Mie' : 'Sab' %></td>
            <td><span class="status-badge status-<%= o.status %>"><%= o.status %></span></td>
            <td><%= o.created_at %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
