<%- include('partials/header') %>

<div class="container">
  <div class="order-section">
    <h2>Resumen de tu pedido #<%= order.id %></h2>

    <table class="checkout-table">
      <thead>
        <tr>
          <th>Producto</th>
          <th>Cantidad</th>
          <th>Precio unit.</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(item => { %>
          <tr>
            <td data-label="Producto"><%= item.product %></td>
            <td data-label="Cantidad"><%= item.quantity %> kg</td>
            <td data-label="Precio unit."><%= formatPrice(item.unit_price) %>/kg</td>
            <td data-label="Subtotal"><%= formatPrice(item.quantity * item.unit_price) %></td>
          </tr>
        <% }) %>
        <% if (order.shipping_cost > 0) { %>
          <tr>
            <td data-label="Concepto">Envío</td>
            <td data-label="Distancia"><%= order.shipping_distance_km ? Math.round(order.shipping_distance_km) + ' km' : '' %></td>
            <td></td>
            <td data-label="Costo"><%= formatPrice(order.shipping_cost) %></td>
          </tr>
        <% } %>
        <tr class="total-row">
          <td colspan="3" data-label="">Total</td>
          <td data-label=""><%= formatPrice(order.total_amount) %></td>
        </tr>
      </tbody>
    </table>

    <div class="customer-summary">
      <p><strong>Nombre:</strong> <%= order.customer_name %></p>
      <p><strong>Teléfono:</strong> <%= order.customer_phone %></p>
      <% if (order.customer_email) { %>
        <p><strong>Email:</strong> <%= order.customer_email %></p>
      <% } %>
      <p><strong>Dirección:</strong> <%= order.customer_address %><% if (order.address_extra) { %> (<%= order.address_extra %>)<% } %></p>
      <p><strong>Entrega:</strong> <%= order.delivery_day === 'miercoles' ? 'Miércoles' : 'Sábado' %><% if (order.delivery_slot) { %> — <%= order.delivery_slot === 'manana' ? 'Mañana (9 a 12hs)' : order.delivery_slot === 'tarde' ? 'Tarde (13 a 17hs)' : 'Noche (18 a 20hs)' %><% } %></p>
    </div>

    <a href="/payment/create/<%= order.id %>" class="btn btn-mp">Pagar con MercadoPago</a>
  </div>
</div>

<%- include('partials/footer') %>
